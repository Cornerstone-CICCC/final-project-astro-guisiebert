---
import Layout from "../../layouts/Layout.astro";
import { ProductCatalog } from "../../models/ProductCatalog.ts";
import type { Product } from "../../models/Product.ts";

export function getStaticPaths() {
  const catalog = new ProductCatalog();
  return catalog.getAllProducts().map((product: Product) => ({
    params: { slug: product.getSlug() },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<Layout title={product.title}>
 

  <!-- Product Detail -->
  <section class="max-w-7xl mx-auto px-8 py-14">
    <div class="grid grid-cols-2 gap-14 items-start">
      <!-- Image -->
      <div class="rounded-3xl overflow-hidden bg-stone-100 aspect-square shadow-sm">
        <img
          src={product.image}
          alt={product.title}
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Info -->
      <div class="flex flex-col gap-6">
        <div>
          <span class="text-xs tracking-widest uppercase text-gold-600">{product.category}</span>
          <h1
            class="mt-2 text-4xl font-light text-stone-800"
            style="font-family: 'Playfair Display', serif;"
          >
            {product.title}
          </h1>
        </div>

        <p class="text-3xl text-gold-700 font-semibold">{product.getFormattedPrice()}</p>

        <p class="text-stone-600 leading-relaxed text-base">{product.description}</p>

        <!-- Button to add to bag -->
        <div class="pt-2">
          {
            product.isInStock() ? (
              <button
                id="add-to-bag"
                class="w-full bg-stone-800 hover:bg-gold-700 text-white text-sm tracking-widest uppercase py-4 rounded-xl font-medium transition-colors duration-300"
              >
                Add to Bag
              </button>
            ) : (
              <button
                disabled
                class="w-full bg-stone-200 text-stone-400 text-sm tracking-widest uppercase py-4 rounded-xl font-medium cursor-not-allowed"
              >
                Unavailable
              </button>
            )
          }
        </div>

        <!-- Meta data -->
        <dl class="border-t border-stone-100 pt-6 grid grid-cols-2 gap-4 text-sm">
          <div>
            <dt class="text-xs uppercase tracking-widest text-stone-400 mb-1">Category</dt>
            <dd class="capitalize text-stone-700">{product.category}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-widest text-stone-400 mb-1">Availability</dt>
            <dd class="text-stone-700">{product.isInStock() ? "Available" : "Sold Out"}</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <script>
    // Add to bag button. Simply changes the text and color when clicked.
    const btn = document.getElementById("add-to-bag");
    if (btn) {
      btn.addEventListener("click", () => {
        btn.textContent = "Added ✓";
        btn.classList.add("bg-emerald-600");
        btn.classList.remove("bg-stone-800", "hover:bg-gold-700");
      });
    }
  </script>
</Layout>
