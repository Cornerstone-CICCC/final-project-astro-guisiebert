---
import type { Product } from "../models/Product.ts";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<div
  class="product-card group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 border border-stone-100"
  data-category={product.category}
>
  <a href={`/products/${product.getSlug()}`} class={`block ${product.isInStock() ? "" : "cursor-not-allowed opacity-50"}`}>
    <div class="relative overflow-hidden aspect-square bg-stone-100">
      <img
        src={product.image}
        alt={product.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
      <div class="absolute top-3 right-3">
        <span class="bg-white/90 text-stone-600 text-xs tracking-widest uppercase px-2 py-1 rounded-full border border-stone-200">
          {product.category}
        </span>
      </div>
    </div>

    <div class="p-5">
      <h2
        class="text-base font-semibold text-stone-800 mb-1 group-hover:text-gold-700 transition-colors"
        style="font-family: 'Playfair Display', serif;"
      >
        {product.title}
      </h2>
      <p class="text-sm text-stone-500 mb-4">
        {product.description}
      </p>
      <div class="flex items-center justify-between">
        <span class="text-gold-700 font-semibold text-lg">
          {product.getFormattedPrice()}
        </span>
        <span
          class={`text-xs px-3 py-1 rounded-full font-medium ${
            product.isInStock()
              ? "bg-emerald-50 text-emerald-700"
              : "bg-stone-800 text-white cursor-not-allowed"
          }`}
        >
          {product.isInStock() ? "In Stock" : "Out of Stock"}
        </span>
      </div>
    </div>
  </a>
</div>
